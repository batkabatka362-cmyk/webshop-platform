# ═══════════════════════════════════════════════
# WEBSHOP — Environment Variables Reference
# ═══════════════════════════════════════════════
# Copy this file: cp .env.example .env.development
# Generate secrets:  openssl rand -hex 32
# ═══════════════════════════════════════════════

# ── Application ────────────────────────────────
NODE_ENV=development
PORT=4000
PLATFORM_VERSION=1.0.0

# ── PostgreSQL ─────────────────────────────────
DATABASE_URL=postgresql://webshop_user:webshop_dev_password@localhost:5432/webshop_db
DATABASE_DIRECT_URL=postgresql://webshop_user:webshop_dev_password@localhost:5432/webshop_db

# ── Redis ──────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── JWT (Customer) ─────────────────────────────
ACCESS_JWT_SECRET=CHANGE_ME_openssl_rand_hex_32
REFRESH_JWT_SECRET=CHANGE_ME_openssl_rand_hex_32
ACCESS_TOKEN_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d
BCRYPT_ROUNDS=12

# ── JWT (Admin) ────────────────────────────────
ADMIN_JWT_SECRET=CHANGE_ME_openssl_rand_hex_32
ADMIN_REFRESH_SECRET=CHANGE_ME_openssl_rand_hex_32
ADMIN_JWT_EXPIRES_IN=8h
ADMIN_REFRESH_EXPIRES_IN=1d
ADMIN_BCRYPT_ROUNDS=12

# ── Internal Token ─────────────────────────────
SYSTEM_INTERNAL_TOKEN=CHANGE_ME_openssl_rand_hex_32

# ── API ────────────────────────────────────────
API_PREFIX=/api
API_VERSION=v1
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:5173
BODY_LIMIT=10mb

# ── QPay Payment Gateway ──────────────────────
QPAY_BASE_URL=https://merchant.qpay.mn/v2
QPAY_USERNAME=
QPAY_PASSWORD=
QPAY_INVOICE_CODE=
PAYMENT_CALLBACK_BASE_URL=http://localhost:4000

# ── Ollama AI ──────────────────────────────────
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# ── Cart ───────────────────────────────────────
CART_MAX_ITEMS=50
CART_MAX_QUANTITY_PER_ITEM=999
CART_GUEST_TTL_SECONDS=86400
CART_USER_TTL_SECONDS=604800
CART_TAX_RATE=0.10
CART_FREE_SHIPPING_THRESHOLD=100000
CART_CURRENCY=MNT

# ── Checkout ───────────────────────────────────
CHECKOUT_SESSION_TTL_SECONDS=900
CHECKOUT_MAX_SESSION_TTL_SECONDS=3600
CHECKOUT_CURRENCY=MNT
CHECKOUT_TAX_RATE=0.10
CHECKOUT_MIN_ORDER_AMOUNT=1000

# ── Inventory ──────────────────────────────────
INVENTORY_LOW_STOCK_THRESHOLD=10
INVENTORY_REORDER_POINT=5
INVENTORY_SOFT_RESERVE_TTL_SEC=1800
INVENTORY_HARD_RESERVE_TTL_SEC=900

# ── Order ──────────────────────────────────────
ORDER_NUMBER_PREFIX=WS
ORDER_NUMBER_SEQUENCE_PAD=6

# ── Media ──────────────────────────────────────
MEDIA_STORAGE_PATH=./uploads
MEDIA_BASE_URL=http://localhost:4000/media

# ── Admin Seed ─────────────────────────────────
ADMIN_EMAIL=admin@webshop.mn
ADMIN_PASSWORD=Admin1234!

# ── Logging ────────────────────────────────────
LOG_LEVEL=debug
