{
  "compilerOptions": {
    "target":              "ES2022",
    "lib":                 ["ES2022"],
    "module":              "CommonJS",
    "moduleResolution":    "node",
    "rootDir":             ".",
    "outDir":              "./dist",
    "strict":              false,
    "noImplicitAny":       false,
    "strictNullChecks":    false,
    "esModuleInterop":     true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule":   true,
    "skipLibCheck":        true,
    "typeRoots": [
      "./node_modules/@types"
    ],
    "types": ["node", "express", "cors", "jsonwebtoken", "bcrypt", "multer", "compression"]
  },
  "include": [
    "backend/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "**/*.test.ts",
    "**/*.spec.ts"
  ]
}
